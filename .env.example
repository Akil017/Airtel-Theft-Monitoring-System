# ═══════════════════════════════════════════════════════
#  AIRTEL BTS THEFT MONITORING SYSTEM — Environment Config
# ═══════════════════════════════════════════════════════

# ── Camera Identity ─────────────────────────────────────
CAMERA_ID=CAM-BTS-01
SITE_ID=AIRTEL-ASM-BTS-001

# ── RTMP Stream ─────────────────────────────────────────
# Camera pushes stream to YOUR SERVER at this URL:
#   rtmp://49.37.110.161:1935/live/bts01
#
# Set in EzyLiv+ app:
#   Settings → RTMP → Enable → Server URL → rtmp://49.37.110.161:1935/live/bts01
#
# Detection service reads from rtmp-server container:
RTSP_URL=rtmp://rtmp-server:1935/live/bts01

# ── CP Plus Hooter (Tuya Cloud API) ─────────────────────
# Get these from iot.tuya.com after linking camera
TUYA_CLIENT_ID=
TUYA_CLIENT_SECRET=
TUYA_DEVICE_ID=
TUYA_REGION=in          # in = India data center

# ── YOLO Detection ──────────────────────────────────────
MODEL_PATH=yolov8s.pt
CONFIDENCE_THRESHOLD=0.45
INFERENCE_EVERY_N_FRAMES=3
EVENT_THROTTLE_SECONDS=2.0
DETECT_CLASSES=0,15,16,17,18,19,20,21,22,23

# ── Business Rules ──────────────────────────────────────
MIN_CONFIDENCE=0.45
CONSECUTIVE_FRAMES_REQUIRED=3
RESTRICTED_SITES=

# ── eNode NOC ───────────────────────────────────────────
ENODE_API_URL=http://enode-noc:9000
ENODE_API_KEY=

# ── Database ────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airtel:airtel@postgres:5432/airtel_monitor

# ── Dashboard ───────────────────────────────────────────
NEXT_PUBLIC_ALARM_MANAGER_WS=ws://49.37.110.161:8002/ws
NEXT_PUBLIC_ALARM_MANAGER_URL=http://49.37.110.161:8002
