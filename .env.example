# ── Detection Service ─────────────────────────────────────────
CAMERA_ID=CAM01
SITE_ID=AIRTEL_ASM_001
RTSP_URL=                          # leave empty for webcam
MODEL_PATH=yolov8n.pt
CONFIDENCE_THRESHOLD=0.70
INFERENCE_EVERY_N_FRAMES=5
EVENT_THROTTLE_SECONDS=2.0

# ── Event Processor ───────────────────────────────────────────
MIN_CONFIDENCE=0.80
CONSECUTIVE_FRAMES_REQUIRED=3
RESTRICTED_SITES=                  # comma-separated, empty = all sites

# ── Alarm Manager ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airtel:airtel@postgres:5432/airtel_monitor
ENODE_API_URL=                     # set when eNode is available
ENODE_API_KEY=

# ── Dashboard ─────────────────────────────────────────────────
NEXT_PUBLIC_ALARM_MANAGER_WS=ws://localhost:8002/ws
NEXT_PUBLIC_ALARM_MANAGER_URL=http://localhost:8002
