# ── Camera ─────────────────────────────────────────────────────────────────
CAMERA_ID=CAM-BTS-01
SITE_ID=AIRTEL-ASM-BTS-001
RTSP_URL=                          # rtsp://admin:pass@192.168.1.64/stream  (leave empty for webcam)

# ── CP Plus Hooter ─────────────────────────────────────────────────────────
# The camera's IP address (same box you pull RTSP from)
# Leave blank to disable hooter control entirely
CPPLUS_CAM_IP=                     # e.g. 192.168.1.64
CPPLUS_USER=admin
CPPLUS_PASS=admin
HOOTER_DURATION_SECONDS=30         # how long hooter rings per human detection

# ── YOLO ──────────────────────────────────────────────────────────────────
MODEL_PATH=yolov8s.pt
CONFIDENCE_THRESHOLD=0.45
INFERENCE_EVERY_N_FRAMES=3

# ── Detection classes (COCO IDs) ──────────────────────────────────────────
# 0=Person, 15-23=Animals
DETECT_CLASSES=0,15,16,17,18,19,20,21,22,23

# ── Business rules ────────────────────────────────────────────────────────
MIN_CONFIDENCE=0.45
CONSECUTIVE_FRAMES_REQUIRED=3
RESTRICTED_SITES=                  # empty = all sites trigger alarms

# ── eNode NOC server ──────────────────────────────────────────────────────
# Point this at your enode-noc container or Vercel deployment
# Local:   http://enode-noc:9000
# Vercel:  https://your-app.vercel.app
ENODE_API_URL=http://enode-noc:9000
ENODE_API_KEY=                     # optional — set if you add auth later

# ── Database ─────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airtel:airtel@postgres:5432/airtel_monitor
