# ── Detection Service ────────────────────────────────────────────────
CAMERA_ID=CAM-BTS-01
SITE_ID=AIRTEL-ASM-BTS-001
RTSP_URL=                           # leave empty to use webcam (/dev/video0)

# YOLO — yolov8s.pt is better accuracy, yolov8n.pt is faster
MODEL_PATH=yolov8s.pt
CONFIDENCE_THRESHOLD=0.45
NMS_IOU_THRESHOLD=0.40
INFERENCE_EVERY_N_FRAMES=3
EVENT_THROTTLE_SECONDS=2.0

# Classes to detect (COCO IDs)
# 0=person 15=cat 16=dog 17=horse 18=sheep
# 19=cow 20=elephant 21=bear 22=zebra 23=giraffe
DETECT_CLASSES=0,15,16,17,18,19,20,21,22,23

# ── Event Processor ───────────────────────────────────────────────────
# Mirrors demo.py severity logic:
#   1-2 intruders = HIGH | 3+ intruders = CRITICAL
MIN_CONFIDENCE=0.45
CONSECUTIVE_FRAMES_REQUIRED=3
RESTRICTED_SITES=                   # comma-separated; empty = all sites trigger alarms

# ── Alarm Manager ─────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airtel:airtel@postgres:5432/airtel_monitor
ENODE_API_URL=                      # set when eNode is available
ENODE_API_KEY=

# ── Dashboard ─────────────────────────────────────────────────────────
NEXT_PUBLIC_ALARM_MANAGER_WS=ws://localhost:8002/ws
NEXT_PUBLIC_ALARM_MANAGER_URL=http://localhost:8002
