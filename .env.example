# ── Detection Service ──────────────────────────────────────────────────────────
CAMERA_ID=CAM-BTS-01
SITE_ID=AIRTEL-ASM-BTS-001
RTSP_URL=                            # leave empty for webcam / RTMP source
MODEL_PATH=yolov8s.pt
CONFIDENCE_THRESHOLD=0.70
INFERENCE_EVERY_N_FRAMES=3
EVENT_THROTTLE_SECONDS=2.0

# ── Event Processor ────────────────────────────────────────────────────────────
MIN_CONFIDENCE=0.75
CONSECUTIVE_FRAMES_REQUIRED=3
RESTRICTED_SITES=                    # comma-separated, empty = all sites

# ── Alarm Manager ──────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airtel:airtel@postgres:5432/airtel_monitor
ALARM_MANAGER_URL=http://alarm-manager:8002
ENODE_API_URL=                       # set when eNode NOC is deployed
ENODE_API_KEY=

# ── Snapshot Storage ───────────────────────────────────────────────────────────
SNAPSHOT_DIR=/shared/snapshots       # shared volume between detection & alarm-manager

# ── Dashboard ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_ALARM_MANAGER_WS=ws://74.225.144.11:8002/ws
NEXT_PUBLIC_ALARM_MANAGER_URL=http://74.225.144.11:8002

# ── WhatsApp Alerts (Twilio) ───────────────────────────────────────────────────
# Sign up at twilio.com → Console → WhatsApp Sandbox
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886   # Twilio sandbox number (free tier)
# For production: buy a Twilio WhatsApp-enabled number and use that instead

# ── CP Plus Integration ────────────────────────────────────────────────────────
CPPLUS_CAM_IP=                       # 192.168.1.64  (leave empty to disable hooter)
CPPLUS_USER=admin
CPPLUS_PASS=admin
HOOTER_DURATION_SECONDS=30

# ── YOLO Performance ───────────────────────────────────────────────────────────
# Classes: 0=person, 15-23=animals
DETECT_CLASSES=0,15,16,17,18,19,20,21,22,23
NMS_IOU_THRESHOLD=0.40
